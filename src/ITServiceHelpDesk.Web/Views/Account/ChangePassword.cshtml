@model ITServiceHelpDesk.Models.ViewModels.Account.ChangePasswordViewModel
@{
    ViewData["Title"] = "Zmień hasło";
}

<div class="page-header">
    <h1 class="page-title">Zmień hasło</h1>
    <p class="page-subtitle">Zaktualizuj swoje hasło dostępu</p>
</div>

<div class="row justify-content-center">
    <div class="col-lg-6">
        <div class="card">
            <div class="card-header">
                <i class="bi bi-key me-2"></i>
                Zmiana hasła
            </div>
            <div class="card-body">
                <form asp-action="ChangePassword" method="post">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>
                    
                    <div class="mb-3">
                        <label asp-for="CurrentPassword" class="form-label">Aktualne hasło</label>
                        <div class="input-group">
                            <span class="input-group-text"><i class="bi bi-lock"></i></span>
                            <input asp-for="CurrentPassword" class="form-control" autocomplete="current-password" />
                        </div>
                        <span asp-validation-for="CurrentPassword" class="text-danger small"></span>
                    </div>
                    
                    <hr class="my-4">
                    
                    <div class="mb-3">
                        <label asp-for="NewPassword" class="form-label">Nowe hasło</label>
                        <div class="input-group">
                            <span class="input-group-text"><i class="bi bi-lock-fill"></i></span>
                            <input asp-for="NewPassword" class="form-control" autocomplete="new-password" />
                        </div>
                        <span asp-validation-for="NewPassword" class="text-danger small"></span>
                        <small class="text-muted">Min. 6 znaków, wielka litera, cyfra, znak specjalny</small>
                    </div>
                    
                    <div class="mb-4">
                        <label asp-for="ConfirmNewPassword" class="form-label">Powtórz nowe hasło</label>
                        <div class="input-group">
                            <span class="input-group-text"><i class="bi bi-lock-fill"></i></span>
                            <input asp-for="ConfirmNewPassword" class="form-control" autocomplete="new-password" />
                        </div>
                        <span asp-validation-for="ConfirmNewPassword" class="text-danger small"></span>
                    </div>
                    
                    <div class="d-flex justify-content-end gap-2">
                        <a asp-action="Profile" class="btn btn-outline-secondary">Anuluj</a>
                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-check-lg me-1"></i>
                            Zmień hasło
                        </button>
                    </div>
                </form>
            </div>
        </div>
        
        <div class="alert alert-info mt-4">
            <i class="bi bi-info-circle me-2"></i>
            <strong>Wskazówki dotyczące bezpiecznego hasła:</strong>
            <ul class="mb-0 mt-2">
                <li>Użyj co najmniej 8 znaków</li>
                <li>Połącz wielkie i małe litery</li>
                <li>Dodaj cyfry i znaki specjalne</li>
                <li>Unikaj oczywistych słów i dat</li>
            </ul>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
