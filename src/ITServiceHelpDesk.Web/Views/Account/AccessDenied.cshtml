@{
    ViewData["Title"] = "Brak dostępu";
}

<div class="d-flex align-items-center justify-content-center" style="min-height: 60vh;">
    <div class="text-center">
        <div class="mb-4">
            <i class="bi bi-shield-x text-danger" style="font-size: 80px;"></i>
        </div>
        <h1 class="display-5 mb-3">Brak dostępu</h1>
        <p class="text-muted mb-4">
            Nie masz uprawnień do wyświetlenia tej strony.<br>
            Skontaktuj się z administratorem, jeśli uważasz, że to błąd.
        </p>
        <div class="d-flex justify-content-center gap-3">
            <a asp-action="Index" asp-controller="Dashboard" class="btn btn-primary">
                <i class="bi bi-house me-2"></i>
                Wróć do Dashboard
            </a>
            <a href="javascript:history.back()" class="btn btn-outline-secondary">
                <i class="bi bi-arrow-left me-2"></i>
                Wróć
            </a>
        </div>
    </div>
</div>
