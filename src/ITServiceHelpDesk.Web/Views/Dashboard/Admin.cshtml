@using ITServiceHelpDesk.Services.Interfaces
@{
    ViewData["Title"] = "Dashboard Admina";
    var stats = ViewBag.Stats as AdminTicketStatsViewModel;
    var userName = (ViewBag.UserName as string ?? User.Identity?.Name ?? "Admin").Split(' ')[0];
}

<!-- Header -->
<div class="page-header d-flex justify-content-between align-items-center">
    <div>
        <h1 class="page-title mb-1">Panel Admina</h1>
        <p class="text-muted mb-0">@DateTime.Now.ToString("dddd, d MMMM yyyy", new System.Globalization.CultureInfo("pl-PL"))</p>
    </div>
    <div class="d-flex gap-2">
        <a asp-controller="Tickets" asp-action="Index" class="btn btn-outline-primary">
            <i class="bi bi-list-ul me-2"></i>Wszystkie zgłoszenia
        </a>
        <a asp-controller="Admin" asp-action="Index" class="btn btn-primary">
            <i class="bi bi-gear me-2"></i>Panel admina
        </a>
    </div>
</div>

<p class="text-muted small fw-semibold text-uppercase mb-2" style="letter-spacing:.05em">Statusy zgłoszeń</p>
<!-- Stat Cards Row 1 - statusy zgłoszeń -->
<div class="row g-3 mb-3">
    <div class="col-6 col-lg-3">
        <div class="card h-100 border-0 shadow-sm">
            <div class="card-body d-flex align-items-center gap-3">
                <div class="rounded-3 p-3" style="background:#ccfbf1">
                    <i class="bi bi-star" style="font-size:1.5rem;color:#14b8a6"></i>
                </div>
                <div>
                    <div class="fw-bold fs-3 lh-1">@(stats?.NewTickets ?? 0)</div>
                    <div class="text-muted small">Nowe</div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-6 col-lg-3">
        <div class="card h-100 border-0 shadow-sm">
            <div class="card-body d-flex align-items-center gap-3">
                <div class="rounded-3 p-3" style="background:#ede9fe">
                    <i class="bi bi-hourglass-split" style="font-size:1.5rem;color:#6366f1"></i>
                </div>
                <div>
                    <div class="fw-bold fs-3 lh-1">@(stats?.InProgressTickets ?? 0)</div>
                    <div class="text-muted small">W realizacji</div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-6 col-lg-3">
        <div class="card h-100 border-0 shadow-sm">
            <div class="card-body d-flex align-items-center gap-3">
                <div class="rounded-3 p-3" style="background:#fef9c3">
                    <i class="bi bi-clock" style="font-size:1.5rem;color:#ca8a04"></i>
                </div>
                <div>
                    <div class="fw-bold fs-3 lh-1">@(stats?.WaitingForUserTickets ?? 0)</div>
                    <div class="text-muted small">Oczekuje na użytkownika</div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-6 col-lg-3">
        <div class="card h-100 border-0 shadow-sm">
            <div class="card-body d-flex align-items-center gap-3">
                <div class="rounded-3 p-3" style="background:#d1fae5">
                    <i class="bi bi-check-circle" style="font-size:1.5rem;color:#059669"></i>
                </div>
                <div>
                    <div class="fw-bold fs-3 lh-1">@(stats?.ResolvedTickets ?? 0)</div>
                    <div class="text-muted small">Rozwiązane</div>
                </div>
            </div>
        </div>
    </div>
</div>

<p class="text-muted small fw-semibold text-uppercase mb-2" style="letter-spacing:.05em">Statystyki ogólne</p>
<!-- Stat Cards Row 2 -->
<div class="row g-3 mb-4">
    <div class="col-6 col-lg-4">
        <div class="card h-100 border-0 shadow-sm">
            <div class="card-body d-flex align-items-center gap-3">
                <div class="rounded-3 p-3" style="background:#fce7f3">
                    <i class="bi bi-plus-circle" style="font-size:1.5rem;color:#db2777"></i>
                </div>
                <div>
                    <div class="fw-bold fs-3 lh-1">@(stats?.TicketsCreatedToday ?? 0)</div>
                    <div class="text-muted small">Dziś nowe</div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-6 col-lg-4">
        <div class="card h-100 border-0 shadow-sm">
            <div class="card-body d-flex align-items-center gap-3">
                <div class="rounded-3 p-3" style="background:#ecfdf5">
                    <i class="bi bi-check2-all" style="font-size:1.5rem;color:#059669"></i>
                </div>
                <div>
                    <div class="fw-bold fs-3 lh-1">@(stats?.TicketsResolvedToday ?? 0)</div>
                    <div class="text-muted small">Dziś rozwiązane</div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-6 col-lg-4">
        <div class="card h-100 border-0 shadow-sm">
            <div class="card-body d-flex align-items-center gap-3">
                <div class="rounded-3 p-3" style="background:#f0fdf4">
                    <i class="bi bi-person-gear" style="font-size:1.5rem;color:#16a34a"></i>
                </div>
                <div>
                    <div class="fw-bold fs-3 lh-1">@(stats?.TotalAgents ?? 0)</div>
                    <div class="text-muted small">Agenci</div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="row g-4">
    <!-- Priority Breakdown -->
    <div class="col-lg-4">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-header bg-transparent border-bottom">
                <h6 class="mb-0 fw-semibold"><i class="bi bi-bar-chart me-2 text-primary"></i>Status zgłoszeń</h6>
            </div>
            <div class="card-body py-2">
                @{
                    var total = stats?.TotalTickets ?? 0;
                    void StatusRow(string name, int count, string color)
                    {
                        var pct = total > 0 ? (int)((double)count / total * 100) : 0;
                        <div class="d-flex align-items-center gap-2 py-2">
                            <div class="rounded-circle" style="width:8px;height:8px;background:@color;flex-shrink:0"></div>
                            <span class="flex-grow-1 small">@name</span>
                            <span class="fw-bold small">@count</span>
                        </div>
                        @if (total > 0 && count > 0)
                        {
                            <div class="progress mb-1" style="height:4px">
                                <div class="progress-bar" style="width:@(pct)%;background:@color"></div>
                            </div>
                        }
                    }
                }
                @{ StatusRow("Nowe", stats?.NewTickets ?? 0, "#14b8a6"); }
                @{ StatusRow("W realizacji", stats?.InProgressTickets ?? 0, "#6366f1"); }
                @{ StatusRow("Oczekujące", stats?.WaitingForUserTickets ?? 0, "#ca8a04"); }
                @{ StatusRow("Rozwiązane", stats?.ResolvedTickets ?? 0, "#10b981"); }
            </div>
        </div>
    </div>

    <!-- Quick Actions -->
    <div class="col-lg-4">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-header bg-transparent border-bottom">
                <h6 class="mb-0 fw-semibold"><i class="bi bi-lightning me-2 text-warning"></i>Szybkie akcje</h6>
            </div>
            <div class="card-body d-grid gap-2">
                <a asp-controller="Tickets" asp-action="Index" class="btn btn-outline-primary">
                    <i class="bi bi-list-ul me-2"></i>Wszystkie zgłoszenia
                </a>
                <a asp-controller="Tickets" asp-action="Unassigned" class="btn btn-outline-warning">
                    <i class="bi bi-inbox me-2"></i>Nieprzypisane zgłoszenia
                </a>
                <a asp-controller="Admin" asp-action="Users" class="btn btn-outline-secondary">
                    <i class="bi bi-people me-2"></i>Zarządzaj użytkownikami
                </a>
                <a asp-controller="Admin" asp-action="Categories" class="btn btn-outline-secondary">
                    <i class="bi bi-tags me-2"></i>Zarządzaj kategoriami
                </a>
                <a asp-controller="Admin" asp-action="AuditLog" class="btn btn-outline-info">
                    <i class="bi bi-journal-text me-2"></i>Log aktywności
                </a>
            </div>
        </div>
    </div>

    <!-- System Status -->
    <div class="col-lg-4">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-header bg-transparent border-bottom">
                <h6 class="mb-0 fw-semibold"><i class="bi bi-server me-2 text-info"></i>Status systemu</h6>
            </div>
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center py-2 border-bottom">
                    <span class="small">Baza danych</span>
                    <span class="badge bg-success">Online</span>
                </div>
                <div class="d-flex justify-content-between align-items-center py-2 border-bottom">
                    <span class="small">Uwierzytelnianie SSO</span>
                    <span class="badge bg-success">Aktywne</span>
                </div>
                <div class="d-flex justify-content-between align-items-center py-2 border-bottom">
                    <span class="small">E-mail</span>
                    <span class="badge bg-secondary">Wyłączony</span>
                </div>
                <div class="d-flex justify-content-between align-items-center py-2">
                    <span class="small">Wersja</span>
                    <span class="badge bg-secondary">1.0.0</span>
                </div>
            </div>
        </div>
    </div>
</div>
