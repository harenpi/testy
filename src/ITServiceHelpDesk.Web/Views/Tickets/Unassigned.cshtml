@model ITServiceHelpDesk.Models.ViewModels.Tickets.TicketListViewModel
@{
    ViewData["Title"] = "Nieprzypisane zgłoszenia";
}

<div class="page-header d-flex justify-content-between align-items-center">
    <div>
        <h1 class="page-title">Nieprzypisane zgłoszenia</h1>
        <p class="page-subtitle">Zgłoszenia oczekujące na przypisanie do agenta</p>
    </div>
    <div class="page-actions">
        <a asp-action="AssignedToMe" class="btn btn-outline-primary me-2">
            <i class="bi bi-person-check me-2"></i>
            Moje zgłoszenia
        </a>
    </div>
</div>

@if (Model.Tickets != null && Model.Tickets.Any())
{
    <div class="alert alert-info mb-4">
        <i class="bi bi-info-circle me-2"></i>
        <strong>@Model.Tickets.TotalCount</strong> zgłoszeń oczekuje na przypisanie. Kliknij "Przejmij", aby przypisać zgłoszenie do siebie.
    </div>

    <div class="row g-4">
        @foreach (var ticket in Model.Tickets)
        {
            <div class="col-lg-6">
                <div class="ticket-card h-100 @(ticket.Priority.ToString() == "Critical" ? "border-danger" : "")">
                    <div class="ticket-card-header">
                        <div>
                            <span class="ticket-number">#@ticket.TicketNumber</span>
                            <span class="badge badge-status-@ticket.Status.ToString().ToLower() ms-2">@ticket.StatusDisplay</span>
                        </div>
                        <span class="badge badge-priority-@ticket.Priority.ToString().ToLower()">@ticket.PriorityDisplay</span>
                    </div>
                    
                    <h5 class="ticket-title">
                        <a asp-action="Details" asp-route-id="@ticket.Id">@ticket.Title</a>
                    </h5>
                    
                    <p class="text-muted text-truncate-2 mb-3">@ticket.Description</p>
                    
                    <div class="ticket-meta">
                        <span class="ticket-meta-item">
                            <i class="bi bi-person"></i>
                            @ticket.RequesterName
                        </span>
                        <span class="ticket-meta-item">
                            <i class="bi bi-folder"></i>
                            @ticket.CategoryName
                        </span>
                        <span class="ticket-meta-item">
                            <i class="bi bi-calendar"></i>
                            @ticket.CreatedAt.ToString("dd.MM.yyyy HH:mm")
                        </span>
                    </div>
                    
                    <div class="mt-3 d-flex gap-2">
                        <form asp-action="Take" asp-controller="Tickets" method="post" class="d-inline">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="ticketId" value="@ticket.Id" />
                            <button type="submit" class="btn btn-sm btn-primary">
                                <i class="bi bi-person-plus me-1"></i>
                                Przejmij
                            </button>
                        </form>
                        <a asp-action="Details" asp-route-id="@ticket.Id" class="btn btn-sm btn-outline-secondary">
                            <i class="bi bi-eye me-1"></i>
                            Podgląd
                        </a>
                    </div>
                </div>
            </div>
        }
    </div>
    
    <!-- Pagination -->
    @if (Model.Tickets.TotalPages > 1)
    {
        <nav class="mt-4">
            <ul class="pagination justify-content-center">
                @if (Model.Tickets.HasPreviousPage)
                {
                    <li class="page-item">
                        <a class="page-link" asp-action="Unassigned" asp-route-page="@(Model.Tickets.PageIndex - 1)">
                            <i class="bi bi-chevron-left"></i>
                        </a>
                    </li>
                }
                @for (int i = 1; i <= Model.Tickets.TotalPages; i++)
                {
                    <li class="page-item @(i == Model.Tickets.PageIndex ? "active" : "")">
                        <a class="page-link" asp-action="Unassigned" asp-route-page="@i">@i</a>
                    </li>
                }
                @if (Model.Tickets.HasNextPage)
                {
                    <li class="page-item">
                        <a class="page-link" asp-action="Unassigned" asp-route-page="@(Model.Tickets.PageIndex + 1)">
                            <i class="bi bi-chevron-right"></i>
                        </a>
                    </li>
                }
            </ul>
        </nav>
    }
}
else
{
    <div class="card">
        <div class="card-body text-center py-5">
            <i class="bi bi-inbox text-muted" style="font-size: 64px;"></i>
            <h5 class="mt-3">Brak nieprzypisanych zgłoszeń</h5>
            <p class="text-muted">Wszystkie zgłoszenia zostały już przypisane do agentów.</p>
            <a asp-action="AssignedToMe" class="btn btn-primary mt-2">
                <i class="bi bi-person-check me-2"></i>Zobacz swoje zgłoszenia
            </a>
        </div>
    </div>
}
