@model ITServiceHelpDesk.Models.ViewModels.Tickets.TicketListViewModel
@using ITServiceHelpDesk.Models.Enums
@using ITServiceHelpDesk.Services.Interfaces
@{
    ViewData["Title"] = "Moje zgłoszenia";

    var allTickets = Model.Tickets?.ToList() ?? new List<ITServiceHelpDesk.Models.ViewModels.Tickets.TicketListItemViewModel>();
    var stats = ViewBag.Stats as UserTicketStatsViewModel ?? new UserTicketStatsViewModel();

    // Mapa: status → krok 0..2
    int StatusStep(TicketStatus s) => s switch
    {
        TicketStatus.New             => 0,
        TicketStatus.InProgress      => 1,
        TicketStatus.WaitingForUser  => 1,
        TicketStatus.Resolved        => 2,
        _                            => 0
    };

    // Kolor lewego paska
    string StatusAccent(TicketStatus s) => s switch
    {
        TicketStatus.New             => "#14b8a6",
        TicketStatus.InProgress      => "#6366f1",
        TicketStatus.WaitingForUser  => "#ca8a04",
        TicketStatus.Resolved        => "#16a34a",
        _                            => "#6b7280"
    };
}

<div class="page-header d-flex justify-content-between align-items-center">
    <div>
        <h1 class="page-title">Moje zgłoszenia</h1>
        <p class="page-subtitle">Zgłoszenia utworzone przez Ciebie</p>
    </div>
    <div class="page-actions">
        <a asp-action="Create" class="btn btn-primary">
            <i class="bi bi-plus-lg me-2"></i>
            Nowe zgłoszenie
        </a>
    </div>
</div>

<!-- Quick Filters z licznikami -->
<div class="d-flex flex-wrap gap-2 mb-4">
    @{
        var currentStatus = Model.Filter?.Status?.ToString();
        string Cls(string? s) => currentStatus == s ? "btn-primary" : "btn-outline-secondary";
    }
    <a asp-action="MyTickets" class="btn @(Model.Filter?.Status == null ? "btn-primary" : "btn-outline-secondary")">
        Wszystkie
        <span class="badge bg-white text-dark ms-1 border border-secondary align-middle">@stats.TotalTickets</span>
    </a>
    <a asp-action="MyTickets" asp-route-status="New" class="btn @Cls("New")">
        <span class="status-dot" style="background:#14b8a6"></span> Nowe
        <span class="badge bg-white text-dark ms-1 border border-secondary align-middle">@stats.NewTickets</span>
    </a>
    <a asp-action="MyTickets" asp-route-status="InProgress" class="btn @Cls("InProgress")">
        <span class="status-dot" style="background:#6366f1"></span> W realizacji
        <span class="badge bg-white text-dark ms-1 border border-secondary align-middle">@stats.InProgressTickets</span>
    </a>
    <a asp-action="MyTickets" asp-route-status="WaitingForUser" class="btn @Cls("WaitingForUser")">
        <span class="status-dot" style="background:#ca8a04"></span> Oczekuje
        <span class="badge bg-white text-dark ms-1 border border-secondary align-middle">@stats.WaitingForUserTickets</span>
    </a>
    <a asp-action="MyTickets" asp-route-status="Resolved" class="btn @Cls("Resolved")">
        <span class="status-dot" style="background:#16a34a"></span> Rozwiązane
        <span class="badge bg-white text-dark ms-1 border border-secondary align-middle">@stats.ResolvedTickets</span>
    </a>
</div>

<!-- Tickets -->
@if (allTickets.Any())
{
    <div class="d-flex flex-column gap-3">
        @foreach (var ticket in allTickets)
        {
            var step   = StatusStep(ticket.StatusEnum);
            var accent = StatusAccent(ticket.StatusEnum);

            <div class="card shadow-sm" style="border-left: 4px solid @accent; border-top:none; border-right:none; border-bottom:none; border-radius:8px;">
                <div class="card-body py-3 px-4">
                    <div class="d-flex justify-content-between align-items-start gap-3">
                        <!-- Left: info -->
                        <div class="flex-grow-1 min-width-0">
                            <div class="d-flex align-items-center gap-2 mb-1 flex-wrap">
                                <span class="text-muted small fw-semibold">#@ticket.TicketNumber</span>
                                <span class="badge badge-priority-@ticket.Priority.ToString().ToLower()">@ticket.PriorityDisplay</span>
                                @if (ticket.IsOverdue)
                                {
                                    <span class="badge bg-danger">
                                        <i class="bi bi-exclamation-circle me-1"></i>Przeterminowane
                                    </span>
                                }
                            </div>

                            <h6 class="mb-2 fw-semibold">
                                <a asp-action="Details" asp-route-id="@ticket.Id" class="text-dark text-decoration-none stretched-link-title">
                                    @ticket.Title
                                </a>
                            </h6>

                            <div class="d-flex flex-wrap gap-3 text-muted small">
                                <span><i class="bi bi-folder me-1"></i>@ticket.CategoryName</span>
                                <span><i class="bi bi-calendar me-1"></i>@ticket.CreatedAt.ToString("dd.MM.yyyy HH:mm")</span>
                                @if (!string.IsNullOrEmpty(ticket.AssignedToName))
                                {
                                    <span><i class="bi bi-person-check me-1"></i>@ticket.AssignedToName</span>
                                }
                                @if (ticket.CommentsCount > 0)
                                {
                                    <span><i class="bi bi-chat me-1"></i>@ticket.CommentsCount</span>
                                }
                            </div>
                        </div>

                        <!-- Right: status tracker + button -->
                        <div class="d-flex flex-column align-items-end gap-3 flex-shrink-0">
                            @{
                                <!-- Progress stepper -->
                                <div class="d-flex align-items-center gap-1" style="white-space:nowrap;">
                                    @{
                                        var steps = new[] {
                                            ("Nowe",      0),
                                            ("W realizacji", 1),
                                            ("Gotowe",    2)
                                        };
                                    }
                                    @for (int i = 0; i < steps.Length; i++)
                                    {
                                        var (label, idx) = steps[i];
                                        bool done    = step > idx;
                                        bool current = step == idx;

                                        <div class="d-flex flex-column align-items-center" style="width:52px;">
                                            <div class="rounded-circle d-flex align-items-center justify-content-center"
                                                 style="width:22px; height:22px; font-size:11px; font-weight:600;
                                                        background: @(done ? accent : current ? accent : "#e5e7eb");
                                                        color: @(done || current ? "white" : "#9ca3af");
                                                        border: 2px solid @(done || current ? accent : "#e5e7eb");">
                                                @if (done)
                                                {
                                                    <i class="bi bi-check" style="font-size:12px;"></i>
                                                }
                                                else
                                                {
                                                    @(i + 1)
                                                }
                                            </div>
                                            <span style="font-size:9px; color:@(done || current ? accent : "#9ca3af"); margin-top:2px; font-weight:@(current ? "700" : "400")">
                                                @label
                                            </span>
                                        </div>

                                        @if (i < steps.Length - 1)
                                        {
                                            <div style="height:2px; width:16px; background:@(step > idx ? accent : "#e5e7eb"); margin-bottom:12px; flex-shrink:0;"></div>
                                        }
                                    }
                                </div>
                            }

                            <a asp-action="Details" asp-route-id="@ticket.Id" class="btn btn-sm btn-outline-primary">
                                <i class="bi bi-eye me-1"></i>Szczegóły
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>

    <!-- Pagination -->
    @if (Model.Tickets!.TotalPages > 1)
    {
        <nav class="mt-4">
            <ul class="pagination justify-content-center">
                @if (Model.Tickets.HasPreviousPage)
                {
                    <li class="page-item">
                        <a class="page-link" asp-action="MyTickets" asp-route-page="@(Model.Tickets.PageIndex - 1)">
                            <i class="bi bi-chevron-left"></i>
                        </a>
                    </li>
                }
                @for (int i = 1; i <= Model.Tickets.TotalPages; i++)
                {
                    <li class="page-item @(i == Model.Tickets.PageIndex ? "active" : "")">
                        <a class="page-link" asp-action="MyTickets" asp-route-page="@i">@i</a>
                    </li>
                }
                @if (Model.Tickets.HasNextPage)
                {
                    <li class="page-item">
                        <a class="page-link" asp-action="MyTickets" asp-route-page="@(Model.Tickets.PageIndex + 1)">
                            <i class="bi bi-chevron-right"></i>
                        </a>
                    </li>
                }
            </ul>
        </nav>
    }
}
else
{
    <div class="card">
        <div class="card-body text-center py-5">
            <i class="bi bi-inbox text-muted" style="font-size: 64px;"></i>
            <h5 class="mt-3">Brak zgłoszeń</h5>
            <p class="text-muted">Nie masz jeszcze żadnych zgłoszeń.</p>
            <a asp-action="Create" class="btn btn-primary mt-2">
                <i class="bi bi-plus-lg me-2"></i>Utwórz pierwsze zgłoszenie
            </a>
        </div>
    </div>
}

<style>
    .status-dot {
        display: inline-block;
        width: 8px;
        height: 8px;
        border-radius: 50%;
        margin-right: 2px;
    }
</style>
