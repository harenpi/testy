@model ITServiceHelpDesk.Models.ViewModels.Tickets.TicketListViewModel
@using ITServiceHelpDesk.Services.Interfaces
@{
    ViewData["Title"] = "Przypisane do mnie";
    var stats = ViewBag.Stats as AgentTicketStatsViewModel ?? new AgentTicketStatsViewModel();
}

<div class="page-header d-flex justify-content-between align-items-start flex-wrap gap-3">
    <div>
        <h1 class="page-title">Przypisane do mnie</h1>
        <p class="page-subtitle">
            @if (Model.Filter?.Status?.ToString() == "Resolved")
            {
                <span>Archiwum — rozwiązane zgłoszenia</span>
            }
            else
            {
                <span>Zgłoszenia wymagające Twojej uwagi</span>
            }
        </p>
    </div>
    <div class="d-flex flex-wrap gap-2">
        <a asp-action="Unassigned" class="btn btn-outline-primary">
            <i class="bi bi-inbox me-2"></i>Nieprzypisane
        </a>
        <a asp-action="Create" class="btn btn-primary">
            <i class="bi bi-plus-lg me-2"></i>Nowe zgłoszenie
        </a>
    </div>
</div>

<!-- Quick Filters -->
@{
    var isArchive = Model.Filter?.Status?.ToString() == "Resolved";
    var isActive = !isArchive;
}
<div class="d-flex flex-wrap gap-2 mb-2">
    <a asp-action="AssignedToMe" class="btn @(Model.Filter?.Status == null ? "btn-primary" : "btn-outline-primary")">
        Aktywne (@stats.AssignedToMe)
    </a>
    <a asp-action="AssignedToMe" asp-route-status="New" class="btn @(Model.Filter?.Status?.ToString() == "New" ? "btn-status-new" : "btn-outline-status-new")">
        Nowe
        <span class="badge bg-white text-dark ms-1 border border-secondary align-middle">@stats.NewTickets</span>
    </a>
    <a asp-action="AssignedToMe" asp-route-status="InProgress" class="btn @(Model.Filter?.Status?.ToString() == "InProgress" ? "btn-status-inprogress" : "btn-outline-status-inprogress")">
        W realizacji
        <span class="badge bg-white text-dark ms-1 border border-secondary align-middle">@stats.InProgressTickets</span>
    </a>
    <a asp-action="AssignedToMe" asp-route-status="WaitingForUser" class="btn @(Model.Filter?.Status?.ToString() == "WaitingForUser" ? "btn-status-waitingforuser" : "btn-outline-status-waitingforuser")">
        Oczekuje
        <span class="badge bg-white text-dark ms-1 border border-secondary align-middle">@stats.WaitingForUserTickets</span>
    </a>
</div>
<div class="d-flex flex-wrap gap-2 mb-4">
    <a asp-action="AssignedToMe" asp-route-status="Resolved" class="btn @(Model.Filter?.Status?.ToString() == "Resolved" ? "btn-status-resolved" : "btn-outline-status-resolved")">
        <i class="bi bi-archive me-1"></i>Archiwum — Rozwiązane
        <span class="badge bg-white text-dark ms-1 border border-secondary align-middle">@stats.ResolvedTickets</span>
    </a>
</div>

<!-- Tickets -->
@if (Model.Tickets != null && Model.Tickets.Any())
{
    <div class="row g-4">
        @foreach (var ticket in Model.Tickets)
        {
            <div class="col-lg-6">
                <div class="ticket-card h-100">
                    <div class="ticket-card-header">
                        <div>
                            <span class="ticket-number">#@ticket.TicketNumber</span>
                            <span class="badge badge-status-@ticket.Status.ToString().ToLower() ms-2">@ticket.StatusDisplay</span>
                        </div>
                        <span class="badge badge-priority-@ticket.Priority.ToString().ToLower()">@ticket.PriorityDisplay</span>
                    </div>
                    
                    <h5 class="ticket-title">
                        <a asp-action="Details" asp-route-id="@ticket.Id">@ticket.Title</a>
                    </h5>
                    
                    <p class="text-muted text-truncate-2 mb-3">@ticket.Description</p>
                    
                    <div class="ticket-meta">
                        <span class="ticket-meta-item">
                            <i class="bi bi-person"></i>
                            @ticket.RequesterName
                        </span>
                        <span class="ticket-meta-item">
                            <i class="bi bi-folder"></i>
                            @ticket.CategoryName
                        </span>
                        <span class="ticket-meta-item">
                            <i class="bi bi-calendar"></i>
                            @ticket.CreatedAt.ToString("dd.MM.yyyy HH:mm")
                        </span>
                    </div>
                    
                    <div class="mt-3 d-flex gap-2">
                        <a asp-action="Details" asp-route-id="@ticket.Id" class="btn btn-sm btn-primary">
                            <i class="bi bi-eye me-1"></i>
                            Otwórz
                        </a>
                    </div>
                </div>
            </div>
        }
    </div>
    
    <!-- Pagination -->
    @if (Model.Tickets.TotalPages > 1)
    {
        <nav class="mt-4">
            <ul class="pagination justify-content-center">
                @if (Model.Tickets.HasPreviousPage)
                {
                    <li class="page-item">
                        <a class="page-link" asp-action="AssignedToMe" asp-route-page="@(Model.Tickets.PageIndex - 1)">
                            <i class="bi bi-chevron-left"></i>
                        </a>
                    </li>
                }
                @for (int i = 1; i <= Model.Tickets.TotalPages; i++)
                {
                    <li class="page-item @(i == Model.Tickets.PageIndex ? "active" : "")">
                        <a class="page-link" asp-action="AssignedToMe" asp-route-page="@i">@i</a>
                    </li>
                }
                @if (Model.Tickets.HasNextPage)
                {
                    <li class="page-item">
                        <a class="page-link" asp-action="AssignedToMe" asp-route-page="@(Model.Tickets.PageIndex + 1)">
                            <i class="bi bi-chevron-right"></i>
                        </a>
                    </li>
                }
            </ul>
        </nav>
    }
}
else
{
    @if (isArchive)
    {
        <div class="card">
            <div class="card-body text-center py-5">
                <i class="bi bi-archive text-muted" style="font-size: 64px;"></i>
                <h5 class="mt-3">Archiwum jest puste</h5>
                <p class="text-muted">Nie masz jeszcze żadnych rozwiązanych zgłoszeń.</p>
            </div>
        </div>
    }
    else
    {
        <div class="card">
            <div class="card-body text-center py-5">
                <i class="bi bi-check-circle text-success" style="font-size: 64px;"></i>
                <h5 class="mt-3">Brak przypisanych zgłoszeń</h5>
                <p class="text-muted">Nie masz obecnie żadnych zgłoszeń do obsługi.</p>
                <a asp-action="Unassigned" class="btn btn-primary mt-2">
                    <i class="bi bi-inbox me-2"></i>Zobacz nieprzypisane zgłoszenia
                </a>
            </div>
        </div>
    }
}
