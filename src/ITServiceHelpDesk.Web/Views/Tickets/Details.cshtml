@model ITServiceHelpDesk.Models.ViewModels.Tickets.TicketDetailsViewModel
@{
    ViewData["Title"] = $"Zgłoszenie #{Model.TicketNumber}";
    var currentUserId = User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
    var isOwner = Model.RequesterId == currentUserId;
    var isAgentOrAdmin = User.IsInRole("Agent") || User.IsInRole("Admin");
    var isAdmin = User.IsInRole("Admin");
}

<div class="page-header d-flex justify-content-between align-items-center flex-wrap gap-2">
    <div>
        <h1 class="page-title mb-0">#@Model.TicketNumber</h1>
    </div>
    <div class="d-flex gap-2">
        @if (isAdmin)
        {
            <form asp-action="Delete" asp-route-id="@Model.Id" method="post" class="d-inline">
                @Html.AntiForgeryToken()
                <button type="submit" class="btn btn-outline-danger"
                        onclick="return confirm('Czy na pewno chcesz usunąć zgłoszenie #@Model.TicketNumber? Tej operacji nie można cofnąć.')">
                    <i class="bi bi-trash me-2"></i>Usuń zgłoszenie
                </button>
            </form>
        }
        <a asp-action="@(isAdmin ? "Index" : "MyTickets")" class="btn btn-outline-secondary">
            <i class="bi bi-arrow-left me-2"></i>Wróć
        </a>
    </div>
</div>

<!-- 1. Opis zgłoszenia -->
<div class="card mb-4">
    <div class="card-header d-flex justify-content-between align-items-center">
        <span><i class="bi bi-card-text me-2"></i>Opis zgłoszenia</span>
        @if (isAgentOrAdmin)
        {
            <button type="button" class="btn btn-link btn-sm text-muted p-0"
                    onclick="toggleEdit('content')" title="Edytuj treść">
                <i class="bi bi-pencil" id="content-icon"></i>
            </button>
        }
    </div>
    <div class="card-body">
        <div id="content-view">
            <p class="fw-semibold mb-2">@Model.Title</p>
            <div style="white-space: pre-wrap;" class="text-muted">@Model.Description</div>
        </div>
        @if (isAgentOrAdmin)
        {
            <form id="content-edit" class="d-none"
                  asp-action="UpdateContent" asp-controller="Tickets" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" name="ticketId" value="@Model.Id" />
                <div class="mb-3">
                    <label class="form-label small fw-semibold">Tytuł</label>
                    <input type="text" name="title" class="form-control"
                           value="@Model.Title" maxlength="200" required />
                </div>
                <div class="mb-3">
                    <label class="form-label small fw-semibold">Opis</label>
                    <textarea name="description" class="form-control" rows="8"
                              required minlength="10">@Model.Description</textarea>
                </div>
                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-primary btn-sm">
                        <i class="bi bi-check me-1"></i>Zapisz
                    </button>
                    <button type="button" class="btn btn-outline-secondary btn-sm"
                            onclick="toggleEdit('content')">Anuluj</button>
                </div>
            </form>
        }
    </div>
</div>

<!-- 2. Informacje -->
<div class="card mb-4">
    <div class="card-header d-flex justify-content-between align-items-center">
        <span><i class="bi bi-info-circle me-2"></i>Informacje</span>
        @if (isAgentOrAdmin)
        {
            <button type="button" class="btn btn-link btn-sm text-muted p-0"
                    onclick="toggleEdit('info')" title="Edytuj informacje">
                <i class="bi bi-pencil" id="info-icon"></i>
            </button>
        }
    </div>
    <div class="card-body">
        <!-- View -->
        <div id="info-view">
            <div class="row g-3">
                <div class="col-6 col-md-3">
                    <p class="text-muted small mb-1">Status</p>
                    <span class="badge @Model.StatusBadgeClass">@Model.StatusDisplay</span>
                </div>
                <div class="col-6 col-md-3">
                    <p class="text-muted small mb-1">Kategoria</p>
                    <strong class="d-block">@Model.CategoryName</strong>
                </div>
                <div class="col-6 col-md-3">
                    <p class="text-muted small mb-1">Priorytet</p>
                    <span class="badge @Model.PriorityBadgeClass">@Model.PriorityDisplay</span>
                </div>
                <div class="col-6 col-md-3">
                    <p class="text-muted small mb-1">Przypisany do</p>
                    @if (!string.IsNullOrEmpty(Model.AssignedToName))
                    {
                        <span class="d-block">@Model.AssignedToName</span>
                    }
                    else
                    {
                        <span class="d-block text-muted fst-italic">Nieprzypisane</span>
                    }
                </div>
                @if (Model.DueDate.HasValue)
                {
                    <div class="col-6 col-md-3">
                        <p class="text-muted small mb-1">SLA / Termin</p>
                        @if (Model.IsOverdue)
                        {
                            <span class="text-danger fw-semibold small d-block">
                                <i class="bi bi-exclamation-circle me-1"></i>@Model.DueDate.Value.ToString("dd.MM.yyyy HH:mm")
                            </span>
                            <small class="text-danger">Przeterminowane</small>
                        }
                        else if (Model.TimeToDeadline.HasValue && Model.TimeToDeadline.Value.TotalHours < 24)
                        {
                            <span class="text-warning fw-semibold small d-block">
                                <i class="bi bi-clock me-1"></i>@Model.DueDate.Value.ToString("dd.MM.yyyy HH:mm")
                            </span>
                            <small class="text-warning">Mniej niż 24h</small>
                        }
                        else
                        {
                            <span class="small d-block">@Model.DueDate.Value.ToString("dd.MM.yyyy HH:mm")</span>
                        }
                    </div>
                }
                <div class="col-6 col-md-3">
                    <p class="text-muted small mb-1">Zgłaszający</p>
                    <span class="d-block">@Model.RequesterName</span>
                </div>
                <div class="col-6 col-md-3">
                    <p class="text-muted small mb-1">Utworzono</p>
                    <span class="d-block small">@Model.CreatedAt.ToString("dd.MM.yyyy HH:mm")</span>
                </div>
                @if (Model.UpdatedAt != Model.CreatedAt)
                {
                    <div class="col-6 col-md-3">
                        <p class="text-muted small mb-1">Aktualizacja</p>
                        <span class="d-block small">@Model.UpdatedAt.ToString("dd.MM.yyyy HH:mm")</span>
                    </div>
                }
                @if (Model.ResolvedAt.HasValue)
                {
                    <div class="col-6 col-md-3">
                        <p class="text-muted small mb-1">Rozwiązano</p>
                        <span class="d-block small">@Model.ResolvedAt.Value.ToString("dd.MM.yyyy HH:mm")</span>
                    </div>
                }
            </div>
        </div>
        <!-- Edit -->
        @if (isAgentOrAdmin)
        {
            <form id="info-edit" class="d-none"
                  asp-action="UpdateInfo" asp-controller="Tickets" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" name="ticketId" value="@Model.Id" />
                <div class="row g-3">
                    <div class="col-md-6">
                        <label class="form-label small fw-semibold">Status</label>
                        <select name="newStatus" id="info-status-select" class="form-select form-select-sm"
                                asp-items="Model.StatusOptions" onchange="toggleResolutionSummary()"></select>
                    </div>
                    <div class="col-md-6 d-none" id="resolution-summary-group">
                        <label class="form-label small fw-semibold">Opis rozwiązania <span class="text-danger">*</span></label>
                        <textarea name="resolutionSummary" class="form-control form-control-sm" rows="2"
                                  placeholder="Opisz co zostało zrobione..."></textarea>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label small fw-semibold">Kategoria</label>
                        <select name="categoryId" class="form-select form-select-sm"
                                asp-items="Model.CategoryOptions"></select>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label small fw-semibold">Priorytet</label>
                        <select name="priority" class="form-select form-select-sm"
                                asp-items="Model.PriorityOptions"></select>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label small fw-semibold">Przypisany agent</label>
                        <select name="assignedToUserId" class="form-select form-select-sm"
                                asp-items="Model.AgentOptions">
                            <option value="">— Nieprzypisane —</option>
                        </select>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label small fw-semibold">Termin (SLA)</label>
                        <input type="datetime-local" name="dueDate" class="form-control form-control-sm"
                               value="@(Model.DueDate.HasValue ? Model.DueDate.Value.ToString("yyyy-MM-ddTHH:mm") : "")" />
                    </div>
                </div>
                <div class="d-flex gap-2 mt-3">
                    <button type="submit" class="btn btn-primary btn-sm">
                        <i class="bi bi-check me-1"></i>Zapisz
                    </button>
                    <button type="button" class="btn btn-outline-secondary btn-sm"
                            onclick="toggleEdit('info')">Anuluj</button>
                </div>
            </form>
        }
    </div>
</div>

<!-- Resolution Summary -->
@if (!string.IsNullOrEmpty(Model.ResolutionSummary))
{
    <div class="card border-success mb-4">
        <div class="card-header text-success">
            <span><i class="bi bi-check-circle-fill me-2"></i>Rozwiązane</span>
        </div>
        <div class="card-body">
            <p class="mb-0" style="white-space: pre-wrap;">@Model.ResolutionSummary</p>
        </div>
    </div>
}

<div class="row g-4 mb-4">
<!-- Owner: Respond when WaitingForUser -->
@if (isOwner && !isAgentOrAdmin && Model.Status == ITServiceHelpDesk.Models.Enums.TicketStatus.WaitingForUser)
{
    <div class="col-12 col-md">
        <div class="card border-status-waitingforuser h-100">
            <div class="card-body p-3">
                <p class="text-muted small text-uppercase fw-semibold mb-2" style="letter-spacing:.05em">
                    <i class="bi bi-reply me-1 text-status-waitingforuser"></i>Oczekujemy na Twoją odpowiedź
                </p>
                <p class="small text-muted mb-3">
                    Agent czeka na dodatkowe informacje. Po udzieleniu odpowiedzi w komentarzu kliknij poniższy przycisk, aby wznowić obsługę zgłoszenia.
                </p>
                <form asp-action="ChangeStatus" asp-controller="Tickets" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="ticketId" value="@Model.Id" />
                    <input type="hidden" name="newStatus" value="2" />
                    <button type="submit" class="btn btn-status-waitingforuser">
                        <i class="bi bi-arrow-right-circle me-2"></i>Odpowiedziałem — wznów obsługę
                    </button>
                </form>
            </div>
        </div>
    </div>
}

<!-- Owner: Close ticket -->
@if (Model.CanClose && !isAgentOrAdmin)
{
    <div class="col-12 col-md">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body p-3">
                <p class="text-muted small text-uppercase fw-semibold mb-2" style="letter-spacing:.05em">Zamknij zgłoszenie</p>
                <p class="small text-muted mb-3">Jeśli problem został rozwiązany lub nie potrzebujesz już pomocy, możesz zamknąć to zgłoszenie.</p>
                <form asp-action="CloseTicket" asp-controller="Tickets" method="post"
                      onsubmit="return confirm('Czy na pewno chcesz zamknąć to zgłoszenie?');">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="ticketId" value="@Model.Id" />
                    <button type="submit" class="btn btn-outline-secondary">
                        <i class="bi bi-x-circle me-2"></i>Zamknij zgłoszenie
                    </button>
                </form>
            </div>
        </div>
    </div>
}
</div>

<!-- Owner: Reopen (within 14 days of resolution) -->
@if (Model.CanReopen)
{
    <div class="card border-warning mb-4">
        <div class="card-body p-3">
            <p class="text-muted small text-uppercase fw-semibold mb-2" style="letter-spacing:.05em">
                <i class="bi bi-exclamation-triangle me-1 text-warning"></i>Niezadowolony z rozwiązania?
            </p>
            <p class="small text-muted mb-3">
                Możesz wznowić zgłoszenie w ciągu 14 dni od jego rozwiązania.
                @if (Model.ResolvedAt.HasValue)
                {
                    var daysLeft = 14 - (int)(DateTime.UtcNow - Model.ResolvedAt.Value).TotalDays;
                    <br /><strong>Pozostało: @daysLeft dni</strong>
                }
            </p>
            <form asp-action="ReopenTicket" asp-controller="Tickets" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" name="ticketId" value="@Model.Id" />
                <button type="submit" class="btn btn-warning">
                    <i class="bi bi-arrow-counterclockwise me-2"></i>Wznów zgłoszenie
                </button>
            </form>
        </div>
    </div>
}

<!-- 3. Załączniki -->
<div class="card mb-4">
    <div class="card-header">
        <span><i class="bi bi-paperclip me-2"></i>Załączniki (@(Model.Attachments?.Count() ?? 0))</span>
    </div>
    <div class="card-body">
        @if (Model.Attachments != null && Model.Attachments.Any())
        {
            <div class="d-flex flex-column gap-2 mb-3">
                @foreach (var attachment in Model.Attachments)
                {
                    <div class="d-flex align-items-center gap-2 p-2 bg-light rounded attachment-row"
                         data-preview-url="@Url.Action("ViewAttachment", "Tickets", new { id = attachment.Id })"
                         data-download-url="@Url.Action("DownloadAttachment", "Tickets", new { id = attachment.Id })"
                         data-content-type="@attachment.ContentType"
                         data-file-name="@attachment.FileName">
                        <div class="flex-shrink-0">
                            @if (attachment.ContentType?.StartsWith("image/") == true)
                            {
                                <i class="bi bi-file-image text-primary" style="font-size:1.25rem"></i>
                            }
                            else if (attachment.ContentType == "application/pdf")
                            {
                                <i class="bi bi-file-pdf text-danger" style="font-size:1.25rem"></i>
                            }
                            else if (attachment.ContentType?.StartsWith("video/") == true)
                            {
                                <i class="bi bi-file-earmark-play text-success" style="font-size:1.25rem"></i>
                            }
                            else
                            {
                                <i class="bi bi-file-earmark text-secondary" style="font-size:1.25rem"></i>
                            }
                        </div>
                        <div class="flex-grow-1 overflow-hidden">
                            <button type="button" class="btn btn-link p-0 text-truncate d-block small fw-medium text-start attachment-preview-btn">@attachment.FileName</button>
                            <small class="text-muted">@attachment.FileSize</small>
                        </div>
                        <div class="flex-shrink-0 d-flex gap-1">
                            <button type="button" class="btn btn-sm btn-outline-secondary attachment-preview-btn" title="Podgląd">
                                <i class="bi bi-eye"></i>
                            </button>
                            <a asp-action="DownloadAttachment" asp-route-id="@attachment.Id"
                               class="btn btn-sm btn-outline-primary" title="Pobierz">
                                <i class="bi bi-download"></i>
                            </a>
                            @if (isOwner || isAgentOrAdmin)
                            {
                                <form asp-action="DeleteAttachment" asp-controller="Tickets" method="post"
                                      onsubmit="return confirm('Czy na pewno chcesz usunąć ten załącznik?');">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@attachment.Id" />
                                    <input type="hidden" name="ticketId" value="@Model.Id" />
                                    <button type="submit" class="btn btn-sm btn-outline-danger" title="Usuń">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                </form>
                            }
                        </div>
                    </div>
                }
            </div>
        }
        else
        {
            <p class="text-muted small mb-3">Brak załączników.</p>
        }
        @if (isOwner || isAgentOrAdmin)
        {
            <form asp-action="UploadAttachment" asp-controller="Tickets" method="post" enctype="multipart/form-data">
                @Html.AntiForgeryToken()
                <input type="hidden" name="ticketId" value="@Model.Id" />
                <div id="attachment-file-list" class="d-flex flex-column gap-2 mb-2"></div>
                <div class="d-flex align-items-center gap-2">
                    <button type="button" id="attachment-add-btn" class="btn btn-outline-secondary btn-sm">
                        <i class="bi bi-plus me-1"></i>Dodaj plik
                    </button>
                    <button type="submit" id="attachment-submit-btn" class="btn btn-primary btn-sm d-none">
                        <i class="bi bi-upload me-1"></i>Prześlij
                    </button>
                </div>
                <div class="form-text">Maks. 100 MB. Dozwolone: jpg, png, gif, pdf, doc, xls, txt, zip, mp4, webm, mov, ogg.</div>
            </form>
        }
    </div>
</div>

<!-- 4. Komentarze -->
<div class="card mb-4">
    <div class="card-header d-flex justify-content-between align-items-center">
        <span>
            <i class="bi bi-chat-dots me-2"></i>
            Komentarze (@(Model.Comments?.Count() ?? 0))
        </span>
    </div>
    <div class="card-body">
        @if (Model.Comments != null && Model.Comments.Any())
        {
            @foreach (var comment in Model.Comments.Where(c => c.IsVisible))
            {
                <div class="comment @(comment.IsInternal ? "internal" : "")">
                    <div class="comment-header">
                        <div class="comment-avatar">
                            @comment.AuthorName?.Substring(0, 1).ToUpper()
                        </div>
                        <div>
                            <span class="comment-author">@comment.AuthorName</span>
                            @if (comment.IsInternal)
                            {
                                <span class="badge bg-warning ms-2">Wewnętrzny</span>
                            }
                        </div>
                        <span class="comment-time ms-auto">@comment.CreatedAt.ToString("dd.MM.yyyy HH:mm")</span>
                    </div>
                    <div class="comment-content">
                        @comment.Content
                    </div>
                </div>
            }
        }
        else
        {
            <p class="text-muted text-center mb-0">Brak komentarzy</p>
        }
    </div>
    <div class="card-footer">
        <form asp-action="AddComment" asp-controller="Tickets" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" name="ticketId" value="@Model.Id" />
            <div class="mb-3">
                <textarea name="content" class="form-control" rows="3"
                          placeholder="Napisz komentarz..." required></textarea>
            </div>
            <div class="d-flex justify-content-between align-items-center">
                @if (isAgentOrAdmin)
                {
                    <div class="form-check">
                        <input type="checkbox" name="isInternal" value="true" class="form-check-input" id="isInternal">
                        <label class="form-check-label" for="isInternal">
                            Komentarz wewnętrzny (widoczny tylko dla agentów)
                        </label>
                    </div>
                }
                else
                {
                    <div></div>
                }
                <button type="submit" class="btn btn-primary">
                    <i class="bi bi-send me-1"></i>Wyślij
                </button>
            </div>
        </form>
    </div>
</div>

<!-- 5. Historia zmian -->
@if (Model.History != null && Model.History.Any())
{
    <div class="card mb-4">
        <div class="card-header d-flex justify-content-between align-items-center"
             role="button" data-bs-toggle="collapse" data-bs-target="#historyCollapse"
             aria-expanded="false" style="cursor:pointer; user-select:none;">
            <span>
                <i class="bi bi-clock-history me-2"></i>
                Historia zmian (@Model.History.Count)
            </span>
            <i class="bi bi-chevron-down" id="historyChevron"></i>
        </div>
        <div id="historyCollapse" class="collapse">
            <div class="card-body">
                <div class="timeline">
                    @foreach (var entry in Model.History)
                    {
                        <div class="timeline-item">
                            <div class="timeline-icon">
                                <i class="bi bi-circle-fill"></i>
                            </div>
                            <div class="timeline-content">
                                <div class="d-flex justify-content-between align-items-start">
                                    <div>
                                        <strong>@entry.FieldName</strong>
                                        @if (!string.IsNullOrEmpty(entry.OldValue) && !string.IsNullOrEmpty(entry.NewValue))
                                        {
                                            <span class="text-muted">zmieniono z</span>
                                            <span class="badge bg-secondary">@entry.OldValue</span>
                                            <span class="text-muted">na</span>
                                            <span class="badge bg-primary">@entry.NewValue</span>
                                        }
                                        else if (!string.IsNullOrEmpty(entry.NewValue))
                                        {
                                            <span class="text-muted">ustawiono na</span>
                                            <span class="badge bg-primary">@entry.NewValue</span>
                                        }
                                    </div>
                                    <small class="timeline-time">@entry.ChangedAt.ToString("dd.MM HH:mm")</small>
                                </div>
                                <small class="text-muted">przez @entry.ChangedByName</small>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
}

<div class="modal fade" id="attachmentPreviewModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-xl modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header py-2">
                <h6 class="modal-title text-truncate me-3" id="attachmentPreviewTitle"></h6>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body p-0" id="attachmentPreviewBody"></div>
            <div class="modal-footer py-2">
                <a id="attachmentPreviewDownload" href="#" class="btn btn-outline-primary btn-sm">
                    <i class="bi bi-download me-1"></i>Pobierz
                </a>
                <button type="button" class="btn btn-secondary btn-sm" data-bs-dismiss="modal">Zamknij</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Pokazuje/ukrywa pole opisu rozwiązania gdy status = Rozwiązany (4)
        function toggleResolutionSummary() {
            const select = document.getElementById('info-status-select');
            const group = document.getElementById('resolution-summary-group');
            if (!select || !group) return;
            const isResolved = select.value === '4';
            group.classList.toggle('d-none', !isResolved);
            group.querySelector('textarea').required = isResolved;
        }

        // Przełączanie trybu edycji sekcji
        function toggleEdit(section) {
            const view = document.getElementById(section + '-view');
            const edit = document.getElementById(section + '-edit');
            const icon = document.getElementById(section + '-icon');
            if (!view || !edit) return;
            const editing = edit.classList.toggle('d-none');
            view.classList.toggle('d-none');
            if (icon) icon.className = editing ? 'bi bi-pencil' : 'bi bi-x-lg';
        }

        // Załączniki
        (function () {
            const ACCEPT = '.jpg,.jpeg,.png,.gif,.pdf,.doc,.docx,.xls,.xlsx,.txt,.zip,.mp4,.webm,.mov,.ogg';
            const fileList = document.getElementById('attachment-file-list');
            const addBtn = document.getElementById('attachment-add-btn');
            const submitBtn = document.getElementById('attachment-submit-btn');
            if (!addBtn) return;

            addBtn.addEventListener('click', function () {
                const row = document.createElement('div');
                row.className = 'd-flex gap-2 align-items-center';
                row.innerHTML = `
                    <input type="file" name="file" class="form-control form-control-sm" accept="${ACCEPT}" />
                    <button type="button" class="btn btn-outline-danger btn-sm flex-shrink-0" onclick="this.closest('div').remove(); updateAttachmentUI();">
                        <i class="bi bi-x-lg"></i>
                    </button>`;
                fileList.appendChild(row);
                updateAttachmentUI();
            });

            function updateAttachmentUI() {
                const hasRows = fileList.children.length > 0;
                submitBtn.classList.toggle('d-none', !hasRows);
                addBtn.disabled = fileList.children.length >= 5;
            }
        })();

        // Podgląd załączników
        (function () {
            const modal = document.getElementById('attachmentPreviewModal');
            if (!modal) return;

            document.querySelectorAll('.attachment-preview-btn').forEach(function (btn) {
                btn.addEventListener('click', function () {
                    const row = this.closest('.attachment-row');
                    const url = row.dataset.previewUrl;
                    const contentType = row.dataset.contentType || '';
                    const fileName = row.dataset.fileName;
                    const downloadUrl = row.dataset.downloadUrl;

                    document.getElementById('attachmentPreviewTitle').textContent = fileName;
                    document.getElementById('attachmentPreviewDownload').href = downloadUrl;

                    const body = document.getElementById('attachmentPreviewBody');
                    if (contentType.startsWith('image/')) {
                        body.innerHTML = '<div class="text-center p-3"><img src="' + url + '" class="img-fluid" style="max-height:75vh;"></div>';
                    } else if (contentType === 'application/pdf') {
                        body.innerHTML = '<iframe src="' + url + '" style="width:100%;height:75vh;border:none;"></iframe>';
                    } else if (contentType.startsWith('video/')) {
                        body.innerHTML = '<video src="' + url + '" controls class="d-block w-100" style="max-height:75vh;background:#000;"></video>';
                    } else {
                        body.innerHTML = '<div class="p-5 text-center text-muted"><i class="bi bi-file-earmark" style="font-size:3rem;"></i><p class="mt-3 mb-0">Podgląd tego typu pliku nie jest dostępny.<br>Pobierz plik, aby go otworzyć.</p></div>';
                    }

                    bootstrap.Modal.getOrCreateInstance(modal).show();
                });
            });

            modal.addEventListener('hidden.bs.modal', function () {
                document.getElementById('attachmentPreviewBody').innerHTML = '';
            });
        })();

        // Obrót strzałki przy rozwijaniu historii
        document.addEventListener('DOMContentLoaded', function () {
            var collapseEl = document.getElementById('historyCollapse');
            if (collapseEl) {
                collapseEl.addEventListener('show.bs.collapse', function () {
                    var chevron = document.getElementById('historyChevron');
                    if (chevron) chevron.style.transform = 'rotate(180deg)';
                });
                collapseEl.addEventListener('hide.bs.collapse', function () {
                    var chevron = document.getElementById('historyChevron');
                    if (chevron) chevron.style.transform = 'rotate(0deg)';
                });
            }
        });
    </script>
}
