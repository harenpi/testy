@model ITServiceHelpDesk.Models.ViewModels.Tickets.TicketEditViewModel
@{
    ViewData["Title"] = $"Edytuj zgłoszenie #{Model.TicketNumber}";
}

<div class="page-header">
    <h1 class="page-title">Edytuj zgłoszenie #@Model.TicketNumber</h1>
    <p class="page-subtitle">Zaktualizuj informacje o zgłoszeniu</p>
</div>

<div class="row">
    <div class="col-lg-8">
        <div class="card">
            <div class="card-header d-flex justify-content-between align-items-center">
                <span>
                    <i class="bi bi-pencil me-2"></i>
                    Edycja zgłoszenia
                </span>
                <span class="badge badge-status-@Model.Status.ToString().ToLower()">@Model.StatusDisplay</span>
            </div>
            <div class="card-body">
                <form asp-action="Edit" method="post" enctype="multipart/form-data">
                    <input type="hidden" asp-for="Id" />
                    <input type="hidden" asp-for="TicketNumber" />
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>
                    
                    <div class="mb-3">
                        <label asp-for="Title" class="form-label">Tytuł zgłoszenia <span class="text-danger">*</span></label>
                        <input asp-for="Title" class="form-control" />
                        <span asp-validation-for="Title" class="text-danger small"></span>
                    </div>
                    
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="CategoryId" class="form-label">Kategoria <span class="text-danger">*</span></label>
                            <select asp-for="CategoryId" asp-items="Model.Categories" class="form-select">
                            </select>
                            <span asp-validation-for="CategoryId" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label asp-for="Priority" class="form-label">Priorytet <span class="text-danger">*</span></label>
                            <select asp-for="Priority" class="form-select">
                                <option value="Low">Niski</option>
                                <option value="Medium">Średni</option>
                                <option value="High">Wysoki</option>
                                <option value="Critical">Krytyczny</option>
                            </select>
                            <span asp-validation-for="Priority" class="text-danger small"></span>
                        </div>
                    </div>
                    
                    @if (User.IsInRole("Agent") || User.IsInRole("Admin"))
                    {
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="Status" class="form-label">Status</label>
                                <select asp-for="Status" class="form-select">
                                    <option value="New">Nowy</option>
                                    <option value="InProgress">W realizacji</option>
                                    <option value="WaitingForUser">Oczekuje na użytkownika</option>
                                    <option value="Resolved">Rozwiązany</option>
                                </select>
                                <span asp-validation-for="Status" class="text-danger small"></span>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label asp-for="AssignedToUserId" class="form-label">Przypisane do</label>
                                <select asp-for="AssignedToUserId" asp-items="Model.Agents" class="form-select">
                                    <option value="">-- Nieprzypisane --</option>
                                </select>
                                <span asp-validation-for="AssignedToUserId" class="text-danger small"></span>
                            </div>
                        </div>
                    }
                    
                    <div class="mb-3">
                        <label asp-for="Description" class="form-label">Opis <span class="text-danger">*</span></label>
                        <textarea asp-for="Description" class="form-control" rows="6"></textarea>
                        <span asp-validation-for="Description" class="text-danger small"></span>
                    </div>
                    
                    <!-- Existing Attachments -->
                    @if (Model.ExistingAttachments != null && Model.ExistingAttachments.Any())
                    {
                        <div class="mb-3">
                            <label class="form-label">Istniejące załączniki</label>
                            <div class="list-group">
                                @foreach (var attachment in Model.ExistingAttachments)
                                {
                                    <div class="list-group-item d-flex justify-content-between align-items-center">
                                        <div>
                                            <i class="bi bi-paperclip me-2"></i>
                                            <a href="@attachment.FilePath" target="_blank">@attachment.FileName</a>
                                            <small class="text-muted ms-2">(@attachment.FileSize)</small>
                                        </div>
                                        <button type="button" class="btn btn-sm btn-outline-danger" 
                                                onclick="removeAttachment(@attachment.Id)">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </div>
                                }
                            </div>
                        </div>
                    }
                    
                    <div class="mb-4">
                        <label asp-for="NewAttachments" class="form-label">Dodaj nowe załączniki</label>
                        <input asp-for="NewAttachments" class="form-control" type="file" multiple accept=".jpg,.jpeg,.png,.gif,.pdf,.doc,.docx,.xls,.xlsx,.txt,.zip" />
                        <small class="text-muted">Maksymalnie 5 plików, każdy do 10 MB.</small>
                    </div>
                    
                    <div class="d-flex justify-content-end gap-2">
                        <a asp-action="Details" asp-route-id="@Model.Id" class="btn btn-outline-secondary">
                            <i class="bi bi-x-lg me-1"></i>
                            Anuluj
                        </a>
                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-check-lg me-1"></i>
                            Zapisz zmiany
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
    
    <div class="col-lg-4">
        <div class="card mb-4">
            <div class="card-header">
                <i class="bi bi-info-circle me-2"></i>
                Informacje
            </div>
            <div class="card-body">
                <p class="mb-2">
                    <strong>Numer:</strong> #@Model.TicketNumber
                </p>
                <p class="mb-2">
                    <strong>Utworzono:</strong> @Model.CreatedAt.ToString("dd.MM.yyyy HH:mm")
                </p>
                @if (Model.UpdatedAt.HasValue)
                {
                    <p class="mb-2">
                        <strong>Ostatnia aktualizacja:</strong> @Model.UpdatedAt.Value.ToString("dd.MM.yyyy HH:mm")
                    </p>
                }
                <p class="mb-0">
                    <strong>Zgłaszający:</strong> @Model.RequesterName
                </p>
            </div>
        </div>
        
        <div class="card">
            <div class="card-header">
                <i class="bi bi-lightning me-2"></i>
                Szybkie akcje
            </div>
            <div class="card-body d-grid gap-2">
                <a asp-action="Details" asp-route-id="@Model.Id" class="btn btn-outline-primary">
                    <i class="bi bi-eye me-2"></i>
                    Zobacz szczegóły
                </a>
                @if (User.IsInRole("Admin"))
                {
                    <form asp-action="Delete" asp-route-id="@Model.Id" method="post" 
                          onsubmit="return confirm('Czy na pewno chcesz usunąć to zgłoszenie?');">
                        <button type="submit" class="btn btn-outline-danger w-100">
                            <i class="bi bi-trash me-2"></i>
                            Usuń zgłoszenie
                        </button>
                    </form>
                }
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        function removeAttachment(attachmentId) {
            if (confirm('Czy na pewno chcesz usunąć ten załącznik?')) {
                // AJAX call to remove attachment
                fetch('/Tickets/RemoveAttachment/' + attachmentId, {
                    method: 'POST',
                    headers: {
                        'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]').value
                    }
                }).then(response => {
                    if (response.ok) {
                        location.reload();
                    }
                });
            }
        }
    </script>
}
