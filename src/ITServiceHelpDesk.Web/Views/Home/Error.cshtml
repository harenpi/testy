@{
    ViewData["Title"] = "Błąd";
    var requestId = ViewBag.RequestId as string;
}

<div class="d-flex align-items-center justify-content-center" style="min-height: 60vh;">
    <div class="text-center">
        <div class="mb-4">
            <i class="bi bi-exclamation-triangle text-warning" style="font-size: 80px;"></i>
        </div>
        <h1 class="display-5 mb-3">Wystąpił błąd</h1>
        <p class="text-muted mb-4">
            Przepraszamy, coś poszło nie tak.<br>
            Spróbuj odświeżyć stronę lub skontaktuj się z administratorem.
        </p>
        
        @if (!string.IsNullOrEmpty(requestId))
        {
            <div class="alert alert-secondary mb-4">
                <strong>Request ID:</strong> @requestId
            </div>
        }
        
        <div class="d-flex justify-content-center gap-3">
            <a asp-action="Index" asp-controller="Home" class="btn btn-primary">
                <i class="bi bi-house me-2"></i>
                Strona główna
            </a>
            <a href="javascript:location.reload()" class="btn btn-outline-secondary">
                <i class="bi bi-arrow-clockwise me-2"></i>
                Odśwież
            </a>
        </div>
    </div>
</div>
