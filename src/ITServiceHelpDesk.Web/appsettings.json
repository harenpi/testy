{
  "ConnectionStrings": {
  "DefaultConnection": "Host=localhost;Database=ITServiceHelpDesk;Username=postgres;Password=postgres"
},
  "AzureAd": {
    "Instance": "https://login.microsoftonline.com/",
    "TenantId": "f803740a-aa70-4574-af69-0879b022f1fe",
    "ClientId": "c057b9db-c7a1-40f9-8519-93e01f440de3",
    "ClientSecret": "",
    "CallbackPath": "/signin-microsoft"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning"
    }
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console"
      },
      {
        "Name": "File",
        "Args": {
          "path": "Logs/log-.txt",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 7
        }
      }
    ]
  },
  "AllowedHosts": "*",
  "AppSettings": {
    "ApplicationName": "IT Service HelpDesk",
    "Version": "1.0.0",
    "MaxFileUploadSizeMB": 100,
    "AllowedFileExtensions": [ ".jpg", ".jpeg", ".png", ".gif", ".pdf", ".doc", ".docx", ".xls", ".xlsx", ".txt", ".zip", ".mp4", ".webm", ".mov", ".ogg" ],
    "TicketNumberPrefix": "HD",
    "DefaultSLAHours": 48,
    "PaginationPageSize": 10
  },
  "EmailSettings": {
    "SmtpServer": "smtp.example.com",
    "SmtpPort": 587,
    "SenderEmail": "helpdesk@company.com",
    "SenderName": "IT HelpDesk",
    "EnableSsl": true,
    "Username": "",
    "Password": ""
  }
}
